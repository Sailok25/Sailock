<UserControl x:Class="Sailock.Views.SetupTotpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">

    <Grid>
        <Border Background="#111111"
                BorderBrush="#00ab26"
                BorderThickness="1"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="36,30">
            <StackPanel>

                <TextBlock Text="ACTIVAR 2FA"
                           Foreground="White"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Escanea este QR con Google Authenticator, Authy o cualquier app TOTP compatible."
                           Foreground="#666666"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- QR Code -->
                <Image Source="{Binding QrImage}"
                       Width="180"
                       Height="180"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

                <!-- Clave manual -->
                <TextBlock Text="O introduce manualmente esta clave:"
                           Foreground="#444444"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock Text="{Binding Secret}"
                           Foreground="#00FF41"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Campo verificación -->
                <TextBlock Text="Introduce el código de 6 dígitos para confirmar:"
                           Foreground="#666666"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBox Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModalTextBoxWithPlaceholder}"
                         Tag="000000"
                         MaxLength="6"
                         HorizontalContentAlignment="Center"
                         Margin="0,0,0,8"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF4D4D"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Visibility="{Binding ErrorMessage,
                                        Converter={StaticResource NullToVisibilityConverter}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="VERIFICAR"
                            Width="130"
                            Style="{StaticResource SailockButton}"
                            Command="{Binding VerifyCommand}"
                            Margin="0,0,16,0"/>
                    <Button Content="CANCELAR"
                            Width="130"
                            Style="{StaticResource SailockButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>