<UserControl x:Class="Sailock.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000"
             Width="Auto"
             Height="Auto">

    <UserControl.Resources>
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
            <Setter Property="BorderBrush" Value="#00ab26"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontFamily" Value="/Fonts/#JetBrains Mono"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="BorderBrush" Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="/Fonts/#JetBrains Mono"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00FF41"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00ab26"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontFamily" Value="/Fonts/#JetBrains Mono"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#4D4D4D"
                                           FontFamily="/Fonts/#JetBrains Mono"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           Margin="{TemplateBinding Padding}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Viewbox MaxWidth="480" MaxHeight="580" Stretch="Uniform"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Width="350">

                <!-- Logo -->
                <Image Source="/Sailock;component/Resources/sailock_logo.png"
                       Height="80" Margin="0,0,0,40"/>

                <!-- Primer uso -->
                <TextBlock Text="{DynamicResource Login_CreateMaster}"
                           Foreground="#00ab26"
                           FontSize="11"
                           FontFamily="/Fonts/#JetBrains Mono"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Error -->
                <TextBlock x:Name="ErrorText"
                           Text="{DynamicResource Login_Error}"
                           Foreground="#FF4D4D"
                           FontSize="11"
                           FontFamily="/Fonts/#JetBrains Mono"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"
                           Visibility="Collapsed"/>

                <!-- PASO 1: Contraseña maestra -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AwaitingTotp}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <PasswordBox x:Name="PasswordInput"
                                 Style="{StaticResource LoginPasswordBox}"
                                 PasswordChanged="PasswordInput_PasswordChanged"
                                 KeyDown="PasswordInput_KeyDown"
                                 Margin="0,0,0,20"/>

                    <Button Style="{StaticResource LoginButton}"
                            Width="160"
                            HorizontalAlignment="Center"
                            Command="{Binding LoginCommand}">
                        <Button.Content>
                            <TextBlock FontFamily="/Fonts/#JetBrains Mono" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Login_Unlock}"/>
                                        <Setter Property="Foreground" Value="#00FF41"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFirstRun}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Login_Create}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- PASO 2: Código TOTP -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AwaitingTotp}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="{DynamicResource Login_TotpLabel}"
                               Foreground="#666666"
                               FontFamily="/Fonts/#JetBrains Mono"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="TotpInput"
                             Text="{Binding TotpCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource LoginTextBox}"
                             Tag="000000"
                             MaxLength="6"
                             HorizontalContentAlignment="Center"
                             KeyDown="TotpInput_KeyDown"
                             Margin="0,0,0,20"/>

                    <Button Content="{DynamicResource Login_TotpVerify}"
                            Width="160"
                            HorizontalAlignment="Center"
                            Style="{StaticResource LoginButton}"/>
                </StackPanel>

                <!-- Versión -->
                <TextBlock Text="v1.5.0"
                           Foreground="#555555"
                           FontSize="10"
                           FontFamily="/Fonts/#JetBrains Mono"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>

            </StackPanel>
        </Viewbox>
    </Grid>
</UserControl>