<UserControl x:Class="Sailock.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">

    <Grid>
        <!-- Contenido principal -->
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0"
                       Text="DASHBOARD"
                       Foreground="White"
                       FontFamily="/Fonts/#Supermolot Light"
                       FontSize="36"
                       Margin="0,0,0,24"/>

            <!-- Barra búsqueda + Add New -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#0D0D0D"
                         Foreground="#00FF41"
                         CaretBrush="#00FF41"
                         BorderBrush="#1A1A1A"
                         BorderThickness="1"
                         Height="38"
                         Padding="14,0"
                         VerticalContentAlignment="Center"
                         FontFamily="/Fonts/#Supermolot Light"
                         FontSize="12"
                         Margin="0,0,12,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button Grid.Column="1"
                        Content="ADD NEW"
                        Width="120"
                        Style="{StaticResource SailockButton}"
                        Command="{Binding OpenAddModalCommand}"/>
            </Grid>

            <!-- Cabecera de la tabla -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="TITLE"
                           Foreground="#444444"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="1" Text="DATA"
                           Foreground="#444444"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"/>
                <TextBlock Grid.Column="2" Text="VALUE"
                           Foreground="#444444"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"/>
                <TextBlock Grid.Column="3" Text="OPTIONS"
                           Foreground="#444444"
                           FontFamily="/Fonts/#Supermolot Light"
                           FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Separador -->
            <Rectangle Grid.Row="2"
                       Height="1"
                       Fill="#1A1A1A"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,-1"/>

            <!-- Lista de entradas -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="52">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <!-- Title -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Title}"
                                           Foreground="White"
                                           FontFamily="/Fonts/#Supermolot Light"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>

                                <!-- Data labels -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Email:" Foreground="#555555"
                                               FontFamily="/Fonts/#Supermolot Light"
                                               FontSize="11"
                                               Visibility="{Binding Email, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="Username:" Foreground="#555555"
                                               FontFamily="/Fonts/#Supermolot Light"
                                               FontSize="11"
                                               Visibility="{Binding Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="Password:" Foreground="#555555"
                                               FontFamily="/Fonts/#Supermolot Light"
                                               FontSize="11"/>
                                </StackPanel>

                                <!-- Values -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="#00FF41"
                                               FontFamily="/Fonts/#Supermolot Light"
                                               FontSize="11"
                                               Visibility="{Binding Email, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Username}"
                                               Foreground="#00FF41"
                                               FontFamily="/Fonts/#Supermolot Light"
                                               FontSize="11"
                                               Visibility="{Binding Username, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="••••••••••"
                                                   Foreground="#00FF41"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <Button Content="[copy]"
                                                Foreground="#00ab26"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontFamily="/Fonts/#Supermolot Light"
                                                FontSize="11"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.CopyPasswordCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Edit -->
                                <Button Grid.Column="3"
                                        Content="[ EDIT ]"
                                        Foreground="#00FF41"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontFamily="/Fonts/#Supermolot Light"
                                        FontSize="12"
                                        Cursor="Hand"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.OpenEditModalCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>

                                <!-- Separador inferior -->
                                <Rectangle Grid.ColumnSpan="4"
                                           Height="1"
                                           Fill="#111111"
                                           VerticalAlignment="Bottom"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Modal Add New -->
        <Grid Visibility="{Binding IsAddModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.7"/>
            <Border Background="#111111"
                    BorderBrush="#00ab26"
                    BorderThickness="1"
                    Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="36,30">
                <StackPanel>
                    <TextBlock Text="ADD NEW"
                               Foreground="White"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="TITLE" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="CATEGORY" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Category, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="USERNAME" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="PASSWORD" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Password, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="NOTE" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Note, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Margin="0,4,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="SAVE"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding SaveNewEntryCommand}"
                                Margin="0,0,16,0"/>
                        <Button Content="CANCEL"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding CancelAddCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Modal Edit -->
        <Grid Visibility="{Binding IsEditModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#000000" Opacity="0.7"/>
            <Border Background="#111111"
                    BorderBrush="#00ab26"
                    BorderThickness="1"
                    Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="36,30">
                <StackPanel>
                    <TextBlock Text="EDIT"
                               Foreground="White"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="TITLE" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="CATEGORY" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Category, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="USERNAME" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="PASSWORD" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Password, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Margin="0,4,0,12"/>

                    <TextBlock Text="NOTE" Style="{StaticResource ModalLabel}"/>
                    <TextBox Text="{Binding EditingEntry.Note, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModalTextBox}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Margin="0,4,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="DELETE"
                                Width="120"
                                Style="{StaticResource SailockButton_Danger}"
                                Command="{Binding DeleteEntryCommand}"
                                Margin="0,0,16,0"/>
                        <Button Content="CANCEL"
                                Width="120"
                                Style="{StaticResource SailockButton}"
                                Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>